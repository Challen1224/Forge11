<Window x:Class="Forge.Studio.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:vm="clr-namespace:Forge.Studio.App.ViewModels"
        Title="Forge Studio"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"/>
                <MenuItem Header="_Open Project"/>
                <Separator/>
                <MenuItem Header="E_xit"/>
            </MenuItem>
            <MenuItem Header="_Edit"/>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Build"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <!-- Docking layout -->
        <avalonDock:DockingManager Grid.Row="1" x:Name="DockManager">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <!-- Left: Solution Explorer / Toolbox -->
                    <avalonDock:LayoutAnchorablePane DockWidth="220">
                        <avalonDock:LayoutAnchorable Title="Solution Explorer" CanClose="False">
                            <TextBlock Text="Solution Explorer" Margin="8"/>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable Title="Toolbox" CanClose="False">
                            <TextBlock Text="Toolbox (Forge11 widgets)" Margin="8"/>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <!-- Center: documents (code editor / .f11 designer / preview) -->
                    <avalonDock:LayoutDocumentPane/>

                    <!-- Right: Properties -->
                    <avalonDock:LayoutAnchorablePane DockWidth="260">
                        <avalonDock:LayoutAnchorable Title="Properties" CanClose="False">
                            <TextBlock Text="Properties" Margin="8"/>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>

                <!-- Bottom: Output / Error List -->
                <avalonDock:LayoutRoot.BottomSide>
                    <avalonDock:LayoutAnchorSide>
                        <avalonDock:LayoutAnchorGroup>
                            <avalonDock:LayoutAnchorable Title="Output" CanClose="False">
                                <TextBlock Text="Output" Margin="8"/>
                            </avalonDock:LayoutAnchorable>
                            <avalonDock:LayoutAnchorable Title="Error List" CanClose="False">
                                <TextBlock Text="Error List" Margin="8"/>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorGroup>
                    </avalonDock:LayoutAnchorSide>
                </avalonDock:LayoutRoot.BottomSide>

            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>