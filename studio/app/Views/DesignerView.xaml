<UserControl x:Class="Forge.Studio.App.Views.DesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Forge.Studio.App.Models">

    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type models:F11TreeNode}"
                                   ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayName}"/>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <TreeView ItemsSource="{Binding ActiveDocument.RootNodes}"/>
    </Grid>

</UserControl>